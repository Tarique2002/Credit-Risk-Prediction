# System Ports
PORT=8000
FRONTEND_URL=http://localhost:5173

# Database Connection
# Defaults to local SQLite file (sqlite:///./credit_risk.db) if empty
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credit_risk

# Security & Authentication
JWT_SECRET=super_secret_cryptographic_random_hash_change_in_production
JWT_REFRESH_SECRET=another_super_secret_refresh_cryptographic_random_hash
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Machine Learning Options
MODEL_DIR=app/ml/artifacts
AUTO_TRAIN_ON_STARTUP=true

# AI Assistant Settings
GEMINI_API_KEY=your_gemini_api_key_here

# Notification Settings (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASSWORD=your_smtp_app_password
EMAIL_FROM=no-reply@creditriskplatform.com

# Cache Settings (Optional)
REDIS_URL=redis://localhost:6379/0
